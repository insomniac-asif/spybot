# QQQBot Environment Variables
# Copy this file to .env and fill in your actual keys:
#   cp .env.template .env

# Alpaca API (required for fetching historical market data)
APCA_API_KEY_ID=your_alpaca_api_key_here
APCA_API_SECRET_KEY=your_alpaca_secret_key_here
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# OpenAI (optional — only needed if backtests use ML predictions or trade analysis)
OPENAI_API_KEY=your_openai_api_key_here

# Dashboard port (default: 8080)
DASHBOARD_PORT=8090

# Discord token — NOT needed for backtesting, leave blank on desktop runner
# DISCORD_TOKEN=
